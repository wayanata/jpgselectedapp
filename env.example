# Google OAuth (Web application client). Either naming works in this app:
#   AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET   (Auth.js default — see Cloudflare vars)
#   GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required for Auth.js (local + Cloudflare Workers). Generate: openssl rand -base64 32
# In Workers: Settings → Variables → Secret → AUTH_SECRET
AUTH_SECRET=

# PostgreSQL (required). Free tier: https://neon.tech — copy the connection string.
# Must include ?sslmode=require for Neon.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Cloudflare / CI: if `prisma migrate deploy` fails with P1002 (advisory lock timeout), use a
# direct Neon connection string for DATABASE_URL on the migrate step (host without `-pooler`),
# or run migrations with retries: `npm run db:deploy:retry` instead of `npx prisma migrate deploy`.

# 1 = Auth.js uses Prisma (Postgres) for sessions. Omit on CI; set on Worker + local .env.
AUTH_USE_PRISMA_ADAPTER=1

# Optional: set to 1 on the Worker temporarily, then open GET /api/health/auth to see which auth env vars are missing (no secrets leaked). Remove when done.
# DEBUG_AUTH_ENV=1

# Local dev
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare Workers: must be the public origin (no trailing path except if you use a custom basePath)
# AUTH_URL="https://jpgselectedapp.YOUR_SUBDOMAIN.workers.dev"
