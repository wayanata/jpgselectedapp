generator client {
  provider = "prisma-client-js"
  // Rust engine not shipped to Workers when using @prisma/adapter-neon + PrismaNeonHTTP in app code.
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  accounts         Account[]
  sessions         Session[]
  /// Legacy: old jobs created when the customer signed in with Google
  customerJobs     Job[]     @relation("JobCustomer")
  /// Jobs whose Drive folder is browsed using this user’s Google tokens
  photographerJobs Job[]     @relation("JobPhotographer")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Job {
  id          String         @id @default(cuid())
  title       String         @default("Selections")
  /// Secret segment for photographer board `/p/[slug]`
  slug        String         @unique
  /// Secret segment for client picker `/pick/[customerToken]` (no Google login)
  customerToken String       @unique
  /// Root Google Drive folder for this job (files must stay under this tree)
  driveFolderId String

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  photographerId String
  photographer   User        @relation("JobPhotographer", fields: [photographerId], references: [id], onDelete: Cascade)

  /// Deprecated: only present on legacy rows from the old customer-sign-in flow
  customerId  String?
  customer    User?          @relation("JobCustomer", fields: [customerId], references: [id], onDelete: SetNull)

  folders     Folder[]
  selections  SelectedFile[]
}

model Folder {
  id        String         @id @default(cuid())
  jobId     String
  job       Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  files     SelectedFile[]
}

model SelectedFile {
  id             String   @id @default(cuid())
  jobId          String
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  folderId       String?
  folder         Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  driveFileId    String
  name           String
  mimeType       String?
  thumbnailLink  String?
  webViewLink    String?
  iconLink       String?
  createdAt      DateTime @default(now())

  @@unique([jobId, driveFileId])
}
